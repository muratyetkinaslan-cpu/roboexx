{
  "name": "roboexx",
  "private": true,
  "version": "2.11.2",
  "type": "module",
  "description": "RoboExx — Pico W tabanlı blok tabanlı programlama uygulaması",
  "scripts": {
    "dev": "vite --host",
    "collab": "node server/index.js",
    "start": "concurrently --names \"collab,vite\" --prefix-colors \"orange,cyan\" --kill-others \"npm:collab\" \"npm:dev\"",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/blockly/media';if(fs.existsSync(p))fs.cpSync(p,'public/blockly-media',{recursive:true,force:true});\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/language": "^6.10.2",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.0",
    "blockly": "^11.1.1",
    "codemirror": "^6.0.1",
    "lib0": "^0.2.94",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^1.5.4",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/web-bluetooth": "^0.0.20",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
